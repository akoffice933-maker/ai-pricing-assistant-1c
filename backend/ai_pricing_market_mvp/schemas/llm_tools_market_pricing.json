          "item": { "type": "object" },
          "market_context": { "type": "object" },
          "demand_curve": { "type": "array", "items": { "type": "object" } },
          "constraints": { "type": "object" }
        },
        "required": ["item", "market_context", "demand_curve"]
      }
    }
  },
  {
    "type": "function",
    "function": {
