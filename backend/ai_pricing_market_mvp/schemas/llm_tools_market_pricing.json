          "price_grid": { "type": "array", "items": { "type": "number" } }
        },
        "required": ["item", "market_context"]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "optimize_price",
      "description": "Выбирает цену по кривой спроса, бизнес-цели и ограничениям маржи. LLM не должна выбирать цену рассуждением.",
