// Фрагмент-патч для AIPricingDataProviderServer.bsl:
// вместо старого запроса product+competitor формируем item+market_context.

Функция СформироватьЗапросРекомендацииЦеныMarketAware(Номенклатура, Характеристика = Неопределено, ВидЦены = Неопределено, БизнесЦель = "maximize_profit") Экспорт

    ТипПозиции = ОпределитьТипПозиции(Номенклатура);
    ТекущаяЦена = ПолучитьТекущуюЦену(Номенклатура, Характеристика, ВидЦены);
    Себестоимость = ПолучитьПолнуюПеременнуюСебестоимость(Номенклатура, Характеристика, ТипПозиции);

    Запрос = Новый Структура;
    Запрос.Вставить("request_id", Строка(Новый УникальныйИдентификатор()));
    Запрос.Вставить("user_id", ИмяПользователя());
    Запрос.Вставить("business_goal", БизнесЦель);
    Запрос.Вставить("horizon_days", 30);

    Item = Новый Структура;
    Item.Вставить("item_id", Строка(Номенклатура.УникальныйИдентификатор()));
    Item.Вставить("item_type", ТипПозиции);
    Item.Вставить("item_name", Строка(Номенклатура));
    Item.Вставить("category", AIPricingMarketContextServer.ОпределитьКатегориюРынка(Номенклатура));
    Item.Вставить("current_price", ТекущаяЦена);
    Item.Вставить("unit_cost", Себестоимость);
    Item.Вставить("price_unit", ?(ТипПозиции = "service", "hour", "unit"));
    Item.Вставить("currency", "EUR");
    Item.Вставить("sales_last_30_days", ПолучитьПродажиЗаПериод(Номенклатура, Характеристика, 30));
    Item.Вставить("sales_last_90_days", ПолучитьПродажиЗаПериод(Номенклатура, Характеристика, 90));
    Item.Вставить("stock_quantity", ?(ТипПозиции = "product", ПолучитьОстаток(Номенклатура, Характеристика), Неопределено));
    Item.Вставить("available_capacity", ?(ТипПозиции = "service", ПолучитьДоступнуюМощностьУслуги(Номенклатура), Неопределено));
    Item.Вставить("team_utilization_percent", ?(ТипПозиции = "service", ПолучитьЗагрузкуКоманды(Номенклатура), Неопределено));
    Item.Вставить("target_margin_percent", ПолучитьЦелевуюМаржу(Номенклатура));
    Item.Вставить("quality_index", ПолучитьИндексЦенности(Номенклатура));

    Запрос.Вставить("item", Item);

    MarketContext = AIPricingMarketContextServer.СформироватьMarketContext(
        Номенклатура,
        Item.category,
        "LV",
        "online",
        ТипПозиции
    );
    Запрос.Вставить("market_context", MarketContext);

    Constraints = Новый Структура;
    Constraints.Вставить("min_margin_percent", 20);
    Constraints.Вставить("max_price_increase_percent", 20);
    Constraints.Вставить("max_price_decrease_percent", 30);
    Constraints.Вставить("price_ending", 0.99);
    Constraints.Вставить("min_confidence_for_apply", 0.70);
    Запрос.Вставить("constraints", Constraints);

    Возврат Запрос;

КонецФункции

Функция ОпределитьТипПозиции(Номенклатура) Экспорт
    // TODO: адаптировать под вашу конфигурацию.
    Попытка
        Если Номенклатура.ВидНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
            Возврат "service";
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат "product";
КонецФункции

Функция ПолучитьПолнуюПеременнуюСебестоимость(Номенклатура, Характеристика, ТипПозиции) Экспорт
    Если ТипПозиции = "service" Тогда
        // Для услуги: стоимость часа специалиста + overhead + внешние расходы.
        Возврат ПолучитьСтоимостьЧасаУслуги(Номенклатура) + ПолучитьOverheadНаЧас(Номенклатура);
    Иначе
        // Для товара: закупка/производство + логистика + комиссии.
        Возврат ПолучитьСебестоимость(Номенклатура, Характеристика) + ПолучитьЛогистическиеРасходы(Номенклатура, Характеристика);
    КонецЕсли;
КонецФункции
