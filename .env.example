# FastAPI optional auth token
AI_PRICING_API_TOKEN=change-me
APP_ENV=development
AI_PRICING_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# GitHub publishing script variables
GITHUB_OWNER=your-github-username
GITHUB_REPO=ai-pricing-assistant-1c
GITHUB_VISIBILITY=public
# Do not save real tokens in this file.
# Export token only in shell session:
# export GITHUB_TOKEN="..."
