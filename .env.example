# --- Runtime environment ---
# development | production
# В production сервис ОБЯЗАТЕЛЬНО требует AI_PRICING_API_TOKEN и не стартует без него.
ENVIRONMENT=development

# --- FastAPI auth ---
AI_PRICING_API_TOKEN=change-me

# --- CORS ---
# Список разрешённых origin через запятую. Пусто = запрещено всё (в т.ч. в dev — secure by default).
# Для локального веб-дашборда (frontend/dashboard, Vite dev-сервер) добавьте его origin:
AI_PRICING_ALLOWED_ORIGINS=http://localhost:5173

# --- Rate limiting ---
# Формат: "<число>/<second|minute|hour>"
AI_PRICING_RATE_LIMIT=60/minute

# --- Logging ---
AI_PRICING_LOG_LEVEL=INFO

# --- GitHub publishing script variables ---
GITHUB_OWNER=your-github-username
GITHUB_REPO=ai-pricing-assistant-1c
GITHUB_VISIBILITY=public
# Do not save real tokens in this file.
# Export token only in shell session:
# export GITHUB_TOKEN="..."
