// Модуль формы AI_MarketRecommendations.
// Требования к реквизитам формы — metadata/FORM_SPEC_STAGE2.md.

&НаКлиенте
Процедура ПриОткрытии(Отказ)
    Если Не ЗначениеЗаполнено(ДатаНачала) Тогда
        ДатаНачала = НачалоДня(ТекущаяДата() - 30 * 24 * 60 * 60);
    КонецЕсли;
    Если Не ЗначениеЗаполнено(ДатаОкончания) Тогда
        ДатаОкончания = КонецДня(ТекущаяДата());
    КонецЕсли;
    Если Не ЗначениеЗаполнено(БизнесЦель) Тогда
        БизнесЦель = "maximize_profit";
    КонецЕсли;
    ОбновитьСписок(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписок(Команда)
    Рекомендации = ПолучитьСписокНаСервере();
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокНаСервере()
    Фильтр = Новый Структура;
    Фильтр.Вставить("ДатаНачала", ДатаНачала);
    Фильтр.Вставить("ДатаОкончания", ДатаОкончания);
    Фильтр.Вставить("Статус", ФильтрСтатус);
    Фильтр.Вставить("MarketCategory", ФильтрMarketCategory);
    Возврат AIPricingRecommendationsMarketServer.ПолучитьСписокMarketAwareРекомендаций(Фильтр);
КонецФункции

&НаКлиенте
Процедура РассчитатьMarketAwareДляТовара(Команда)
    Если Не ЗначениеЗаполнено(ТекущаяНоменклатура) Тогда
        Сообщить("Выберите номенклатуру.");
        Возврат;
    КонецЕсли;
    Попытка
        Результат = РассчитатьMarketAwareДляТовараНаСервере(ТекущаяНоменклатура, БизнесЦель);
        Сообщить("Рекомендация рассчитана: " + Строка(Результат.recommended_price));
        ОбновитьСписок(Неопределено);
    Исключение
        Сообщить("Ошибка расчёта: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры

&НаСервере
Функция РассчитатьMarketAwareДляТовараНаСервере(Номенклатура, БизнесЦель)
    Возврат AIPricingRecommendationsMarketServer.РассчитатьИЗаписатьMarketAwareРекомендацию(Номенклатура, Неопределено, Неопределено, БизнесЦель);
КонецФункции

&НаКлиенте
Процедура ПоказатьКривуюСпроса(Команда)
    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;
    JSON = AIPricingRecommendationsMarketServer.ПолучитьКривуюСпросаJSON(Идентификатор);
    Сообщить("Кривая спроса:" + Символы.ПС + JSON);
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьMarketContext(Команда)
    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;
    JSON = AIPricingRecommendationsMarketServer.ПолучитьMarketContextJSON(Идентификатор);
    Сообщить("Market context:" + Символы.ПС + JSON);
КонецПроцедуры

&НаКлиенте
Процедура ПринятьРекомендацию(Команда)
    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;
    AIPricingRecommendationsServer.ОбновитьСтатусРекомендации(Идентификатор, "Принята");
    ОбновитьСписок(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ОтклонитьРекомендацию(Команда)
    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;
    Причина = "";
    ВвестиСтроку(Причина, "Укажите причину отклонения", 500);
    Если Не ЗначениеЗаполнено(Причина) Тогда
        Сообщить("Причина отклонения обязательна.");
        Возврат;
    КонецЕсли;
    AIPricingRecommendationsServer.ОбновитьСтатусРекомендации(Идентификатор, "Отклонена", Причина);
    ОбновитьСписок(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументЦен(Команда)
    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;
    Попытка
        Результат = AIPricingDocumentsServer.СоздатьЧерновикУстановкиЦен(Идентификатор);
        Сообщить("Создан непроведённый документ: " + Строка(Результат.ДокументСсылка));
        ОбновитьСписок(Неопределено);
    Исключение
        Сообщить("Ошибка создания документа: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры

&НаКлиенте
Функция ПолучитьИдентификаторТекущейРекомендации()
    Если Элементы.Рекомендации.ТекущиеДанные = Неопределено Тогда
        Сообщить("Выберите рекомендацию.");
        Возврат "";
    КонецЕсли;
    Возврат Элементы.Рекомендации.ТекущиеДанные.ИдентификаторРекомендации;
КонецФункции
