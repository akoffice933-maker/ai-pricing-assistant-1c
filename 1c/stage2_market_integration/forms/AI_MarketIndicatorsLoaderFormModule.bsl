// Модуль формы AI_MarketIndicatorsLoader.
// Реквизиты: ТекстДанных, ФорматДанных, РазделительCSV, РезультатЗагрузки.

&НаКлиенте
Процедура ПриОткрытии(Отказ)
    Если Не ЗначениеЗаполнено(ФорматДанных) Тогда
        ФорматДанных = "json";
    КонецЕсли;
    Если Не ЗначениеЗаполнено(РазделительCSV) Тогда
        РазделительCSV = ";";
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзТекста(Команда)
    Если Не ЗначениеЗаполнено(ТекстДанных) Тогда
        Сообщить("Вставьте JSON или CSV с рыночными индикаторами.");
        Возврат;
    КонецЕсли;
    Попытка
        Итог = ЗагрузитьИзТекстаНаСервере(ТекстДанных, ФорматДанных, РазделительCSV);
        РезультатЗагрузки = "Загружено: " + Строка(Итог.Загружено) + ", ошибок: " + Строка(Итог.Ошибок);
        Сообщить(РезультатЗагрузки);
    Исключение
        Сообщить("Ошибка загрузки: " + ОписаниеОшибки());
    КонецПопытки;
КонецПроцедуры

&НаСервере
Функция ЗагрузитьИзТекстаНаСервере(Текст, Формат, Разделитель)
    Если НРег(Формат) = "json" Тогда
        Возврат AIPricingMarketIndicatorsLoaderServer.ЗагрузитьИзJSONСтроки(Текст);
    ИначеЕсли НРег(Формат) = "csv" Тогда
        Возврат AIPricingMarketIndicatorsLoaderServer.ЗагрузитьИзCSVСтроки(Текст, Разделитель);
    Иначе
        ВызватьИсключение "Неизвестный формат: " + Формат;
    КонецЕсли;
КонецФункции

&НаКлиенте
Процедура Очистить(Команда)
    ТекстДанных = "";
    РезультатЗагрузки = "";
КонецПроцедуры
