// ОбщийМодуль AIPricingMarketIndicatorsLoaderServer
// Свойства: Сервер = Истина, ВызовСервера = Истина.
// Назначение: загрузка рыночных индикаторов в регистр AI_РыночныеИндикаторы.

Функция ЗагрузитьИзJSONСтроки(ТекстJSON, ИсточникДанныхПоУмолчанию = "manual") Экспорт

    Данные = ПрочитатьJSONИзСтроки(ТекстJSON);
    Если ТипЗнч(Данные) <> Тип("Массив") Тогда
        ВызватьИсключение "JSON должен быть массивом объектов индикаторов.";
    КонецЕсли;

    Итог = Новый Структура;
    Итог.Вставить("Загружено", 0);
    Итог.Вставить("Ошибок", 0);
    Итог.Вставить("Ошибки", Новый Массив);

    Для Каждого Элемент Из Данные Цикл
        Попытка
            ЗаписатьИндикатор(Элемент, ИсточникДанныхПоУмолчанию);
            Итог.Загружено = Итог.Загружено + 1;
        Исключение
            Итог.Ошибок = Итог.Ошибок + 1;
            Итог.Ошибки.Добавить(ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;

    Возврат Итог;

КонецФункции

Функция ЗагрузитьИзCSVСтроки(ТекстCSV, Разделитель = ";", ИсточникДанныхПоУмолчанию = "manual_csv") Экспорт

    Строки = СтрРазделить(ТекстCSV, Символы.ПС, Ложь);
    Если Строки.Количество() < 2 Тогда
        ВызватьИсключение "CSV должен содержать заголовок и минимум одну строку данных.";
    КонецЕсли;

    Заголовки = СтрРазделить(Строки[0], Разделитель, Ложь);

    Итог = Новый Структура;
    Итог.Вставить("Загружено", 0);
    Итог.Вставить("Ошибок", 0);
    Итог.Вставить("Ошибки", Новый Массив);

    Для НомерСтроки = 1 По Строки.Количество() - 1 Цикл
        СтрокаCSV = СокрЛП(Строки[НомерСтроки]);
        Если СтрокаCSV = "" Тогда
            Продолжить;
        КонецЕсли;

        Значения = СтрРазделить(СтрокаCSV, Разделитель, Ложь);
        Объект = Новый Структура;

        Для Индекс = 0 По Заголовки.Количество() - 1 Цикл
            ИмяПоля = СокрЛП(Заголовки[Индекс]);
            ЗначениеПоля = "";
            Если Индекс < Значения.Количество() Тогда
                ЗначениеПоля = СокрЛП(Значения[Индекс]);
            КонецЕсли;
            Объект.Вставить(ИмяПоля, ЗначениеПоля);
        КонецЦикла;

        Попытка
            НормализоватьCSVОбъект(Объект);
            ЗаписатьИндикатор(Объект, ИсточникДанныхПоУмолчанию);
            Итог.Загружено = Итог.Загружено + 1;
        Исключение
            Итог.Ошибок = Итог.Ошибок + 1;
            Итог.Ошибки.Добавить("Строка " + Строка(НомерСтроки + 1) + ": " + ОписаниеОшибки());
        КонецПопытки;
    КонецЦикла;

    Возврат Итог;

КонецФункции

Процедура ЗаписатьИндикатор(Данные, ИсточникДанныхПоУмолчанию = "manual") Экспорт

    Если Метаданные.РегистрыСведений.Найти("AI_РыночныеИндикаторы") = Неопределено Тогда
        ВызватьИсключение "Не найден регистр сведений AI_РыночныеИндикаторы.";
    КонецЕсли;

    КатегорияРынка = ПолучитьСвойство(Данные, "market_category", "");
    Если КатегорияРынка = "" Тогда
        КатегорияРынка = ПолучитьСвойство(Данные, "КатегорияРынка", "");
    КонецЕсли;
    Если КатегорияРынка = "" Тогда
        ВызватьИсключение "Не заполнена market_category.";
    КонецЕсли;

    Запись = РегистрыСведений.AI_РыночныеИндикаторы.СоздатьМенеджерЗаписи();
    Запись.Период = ПолучитьДатуПериода(Данные);
    Запись.КатегорияРынка = КатегорияРынка;
    Запись.Регион = ПолучитьСвойство(Данные, "region", ПолучитьСвойство(Данные, "Регион", "LV"));
    Запись.КаналПродаж = ПолучитьСвойство(Данные, "channel", ПолучитьСвойство(Данные, "КаналПродаж", "online"));
    Запись.ТипПозиции = ПолучитьСвойство(Данные, "item_type", ПолучитьСвойство(Данные, "ТипПозиции", "product"));
    Запись.ИсточникДанных = ПолучитьСвойство(Данные, "source", ИсточникДанныхПоУмолчанию);

    Запись.MarketPriceMin = ЧислоСвойства(Данные, "market_price_min", 0);
    Запись.MarketPriceP25 = ЧислоСвойства(Данные, "market_price_p25", 0);
    Запись.MarketPriceMedian = ЧислоСвойства(Данные, "market_price_median", 0);
    Запись.MarketPriceAvg = ЧислоСвойства(Данные, "market_price_avg", 0);
    Запись.MarketPriceP75 = ЧислоСвойства(Данные, "market_price_p75", 0);
    Запись.MarketPriceMax = ЧислоСвойства(Данные, "market_price_max", 0);
    Запись.CompetitorCount = ЧислоСвойства(Данные, "competitor_count", 0);
    Запись.ActiveCompetitorCount = ЧислоСвойства(Данные, "active_competitor_count", 0);
    Запись.MarketDemandIndex = ЧислоСвойства(Данные, "market_demand_index", 1);
    Запись.SearchTrendIndex = ЧислоСвойства(Данные, "search_trend_index", 0);
    Запись.LeadVolumeIndex = ЧислоСвойства(Данные, "lead_volume_index", 0);
    Запись.CategoryViewsIndex = ЧислоСвойства(Данные, "category_views_index", 0);
    Запись.PromoShare = ЧислоСвойства(Данные, "promo_share", 0);
    Запись.AverageDiscountPercent = ЧислоСвойства(Данные, "average_discount_percent", 0);
    Запись.AvailabilityIndex = ЧислоСвойства(Данные, "availability_index", 1);
    Запись.StockoutRate = ЧислоСвойства(Данные, "stockout_rate", 0);
    Запись.AverageDeliveryDays = ЧислоСвойства(Данные, "average_delivery_days", 0);
    Запись.SeasonalityIndex = ЧислоСвойства(Данные, "seasonality_index", 1);
    Запись.TenderCount = ЧислоСвойства(Данные, "tender_count", 0);
    Запись.ConversionBenchmark = ЧислоСвойства(Данные, "conversion_benchmark", 0);
    Запись.SpecialistSupplyIndex = ЧислоСвойства(Данные, "specialist_supply_index", 0);
    Запись.WageIndex = ЧислоСвойства(Данные, "wage_index", 0);
    Запись.DataFreshnessDays = ЧислоСвойства(Данные, "data_freshness_days", 0);
    Запись.SourceCount = ЧислоСвойства(Данные, "source_count", 0);
    Запись.CoverageScore = ЧислоСвойства(Данные, "coverage_score", 1);
    Запись.Confidence = ЧислоСвойства(Данные, "confidence", 0.5);

    Запись.Currency = ПолучитьСвойство(Данные, "currency", "EUR");
    Запись.RawDataJSON = ЗаписатьJSONВСтроку(Данные);
    Запись.CalculationMethod = ПолучитьСвойство(Данные, "calculation_method", "manual_load");
    Запись.LoadedAt = ТекущаяДата();
    Запись.Comment = ПолучитьСвойство(Данные, "comment", "");

    Если Запись.MarketPriceMedian <= 0 Тогда
        ВызватьИсключение "market_price_median должен быть больше 0.";
    КонецЕсли;

    Запись.Записать();

КонецПроцедуры

Функция ПолучитьДатуПериода(Данные)
    Период = ПолучитьСвойство(Данные, "period", "");
    Если Период = "" Тогда
        Возврат ТекущаяДата();
    КонецЕсли;
    Попытка
        // Поддержка формата yyyy-MM через первое число месяца.
        Если СтрДлина(Период) = 7 Тогда
            Возврат Дата(Лев(Период, 4) + Сред(Период, 6, 2) + "01");
        КонецЕсли;
        Возврат Дата(Период);
    Исключение
        Возврат ТекущаяДата();
    КонецПопытки;
КонецФункции

Процедура НормализоватьCSVОбъект(Объект)
    // Преобразуем числовые строки с запятой в числа там, где это возможно.
    Для Каждого КлючИЗначение Из Объект Цикл
        Значение = КлючИЗначение.Значение;
        Если ТипЗнч(Значение) = Тип("Строка") Тогда
            Если ЭтоПохожеНаЧисло(Значение) Тогда
                Объект[КлючИЗначение.Ключ] = ЧислоИзСтроки(Значение);
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

Функция ЭтоПохожеНаЧисло(СтрокаЗначение)
    СтрокаЗначение = СтрЗаменить(СтрокаЗначение, ",", ".");
    Возврат СтрНайти("0123456789-.", Лев(СтрокаЗначение, 1)) > 0;
КонецФункции

Функция ЧислоИзСтроки(Значение)
    Если ТипЗнч(Значение) = Тип("Число") Тогда
        Возврат Значение;
    КонецЕсли;
    Если Значение = Неопределено Или Значение = Null Или Значение = "" Тогда
        Возврат 0;
    КонецЕсли;
    СтрокаЧисла = Строка(Значение);
    Попытка
        Возврат Число(СтрЗаменить(СтрокаЧисла, ".", ","));
    Исключение
        Возврат Число(СтрЗаменить(СтрокаЧисла, ",", "."));
    КонецПопытки;
КонецФункции

Функция ЧислоСвойства(Данные, ИмяСвойства, ЗначениеПоУмолчанию)
    Значение = ПолучитьСвойство(Данные, ИмяСвойства, ЗначениеПоУмолчанию);
    Попытка
        Возврат ЧислоИзСтроки(Значение);
    Исключение
        Возврат ЗначениеПоУмолчанию;
    КонецПопытки;
КонецФункции

Функция ПолучитьСвойство(Данные, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
    Если Данные = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;
    Значение = Неопределено;
    Попытка
        Если Данные.Свойство(ИмяСвойства, Значение) Тогда
            Если Значение = Null Тогда
                Возврат ЗначениеПоУмолчанию;
            КонецЕсли;
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЗаписатьJSONВСтроку(Данные)
    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция ПрочитатьJSONИзСтроки(СтрокаJSON)
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
    Данные = ПрочитатьJSON(ЧтениеJSON);
    ЧтениеJSON.Закрыть();
    Возврат Данные;
КонецФункции
