// ОбщийМодуль AIPricingDataProviderMarketServer
// Свойства: Сервер = Истина, ВызовСервера = Ложь.
// Назначение: сбор внутренних данных 1С + market_context в контракт нового FastAPI.

Функция СформироватьЗапросMarketAware(Номенклатура, Характеристика = Неопределено, ВидЦены = Неопределено, БизнесЦель = "") Экспорт

    Если БизнесЦель = "" Тогда
        БизнесЦель = ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_DefaultBusinessGoal", "maximize_profit");
    КонецЕсли;

    ГоризонтДней = ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_DefaultHorizonDays", 30);
    ТипПозиции = AIPricingMarketContextServer.ОпределитьТипПозиции(Номенклатура);
    Маппинг = AIPricingMarketContextServer.ПолучитьМаппингРыночнойКатегории(Номенклатура);

    ТекущаяЦена = ПолучитьТекущуюЦену(Номенклатура, Характеристика, ВидЦены);
    UnitCost = ПолучитьПолнуюПеременнуюСебестоимость(Номенклатура, Характеристика, ТипПозиции);

    Если ТекущаяЦена <= 0 Тогда
        ВызватьИсключение "Не определена текущая цена позиции.";
    КонецЕсли;

    Запрос = Новый Структура;
    Запрос.Вставить("request_id", Строка(Новый УникальныйИдентификатор()));
    Запрос.Вставить("user_id", ИмяПользователя());
    Запрос.Вставить("business_goal", БизнесЦель);
    Запрос.Вставить("horizon_days", ГоризонтДней);

    Item = Новый Структура;
    Item.Вставить("item_id", ПолучитьИдентификаторСсылки(Номенклатура));
    Item.Вставить("item_type", ТипПозиции);
    Item.Вставить("item_name", Строка(Номенклатура));
    Item.Вставить("category", AIPricingMarketContextServer.ОпределитьКатегориюРынкаFallback(Номенклатура));
    Item.Вставить("current_price", ТекущаяЦена);
    Item.Вставить("unit_cost", UnitCost);
    Item.Вставить("price_unit", ПолучитьСвойство(Маппинг, "PriceUnit", ?(ТипПозиции = "service", "hour", "unit")));
    Item.Вставить("currency", "EUR");
    Item.Вставить("sales_last_30_days", ПолучитьПродажиЗаПериод(Номенклатура, Характеристика, 30, ТипПозиции));
    Item.Вставить("sales_last_90_days", ПолучитьПродажиЗаПериод(Номенклатура, Характеристика, 90, ТипПозиции));
    Item.Вставить("stock_quantity", ?(ТипПозиции = "product", ПолучитьОстаток(Номенклатура, Характеристика), Неопределено));
    Item.Вставить("available_capacity", ?(ТипПозиции = "service", ПолучитьДоступнуюМощностьУслуги(Номенклатура), Неопределено));
    Item.Вставить("team_utilization_percent", ?(ТипПозиции = "service", ПолучитьЗагрузкуКоманды(Номенклатура), Неопределено));
    Item.Вставить("target_margin_percent", ПолучитьЦелевуюМаржу(Номенклатура));
    Item.Вставить("quality_index", ПолучитьИндексЦенности(Номенклатура, Маппинг));
    Item.Вставить("conversion_rate_percent", ?(ТипПозиции = "service", ПолучитьКонверсиюУслуги(Номенклатура), Неопределено));
    Запрос.Вставить("item", Item);

    MarketContext = AIPricingMarketContextServer.СформироватьMarketContext(Номенклатура, "", "", ТипПозиции);
    Запрос.Вставить("market_context", MarketContext);

    Constraints = Новый Структура;
    Constraints.Вставить("min_margin_percent", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MinMarginPercent", 20));
    Constraints.Вставить("max_price_increase_percent", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MaxIncreasePercent", 20));
    Constraints.Вставить("max_price_decrease_percent", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MaxDecreasePercent", 30));
    Constraints.Вставить("price_ending", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_PriceEnding", 0.99));
    Constraints.Вставить("min_confidence_for_apply", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MinConfidence", 0.70));
    Запрос.Вставить("constraints", Constraints);

    Возврат Запрос;

КонецФункции

Функция ПолучитьТекущуюЦену(Номенклатура, Характеристика, ВидЦены) Экспорт
    Попытка
        Возврат AIPricingDataProviderServer.ПолучитьТекущуюЦену(Номенклатура, Характеристика, ВидЦены);
    Исключение
    КонецПопытки;
    Возврат 0;
КонецФункции

Функция ПолучитьПолнуюПеременнуюСебестоимость(Номенклатура, Характеристика, ТипПозиции) Экспорт
    Если ТипПозиции = "service" Тогда
        Возврат ПолучитьСтоимостьЧасаУслуги(Номенклатура) + ПолучитьOverheadНаЧас(Номенклатура) + ПолучитьВнешниеРасходыНаЕдиницуУслуги(Номенклатура);
    Иначе
        Возврат ПолучитьСебестоимостьТовара(Номенклатура, Характеристика) + ПолучитьЛогистическиеРасходы(Номенклатура, Характеристика) + ПолучитьКомиссииКанала(Номенклатура);
    КонецЕсли;
КонецФункции

