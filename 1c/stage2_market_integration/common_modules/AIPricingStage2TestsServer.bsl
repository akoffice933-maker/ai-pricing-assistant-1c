// ОбщийМодуль AIPricingStage2TestsServer
// Свойства: Сервер = Истина, ВызовСервера = Истина.
// Назначение: smoke-тесты Этапа 2.

Функция ВыполнитьSmokeTests(ТестоваяНоменклатура) Экспорт

    Результат = Новый Структура;
    Результат.Вставить("Health", Неопределено);
    Результат.Вставить("ModelInfo", Неопределено);
    Результат.Вставить("MarketContext", Неопределено);
    Результат.Вставить("Recommendation", Неопределено);
    Результат.Вставить("Ошибки", Новый Массив);

    Попытка
        Результат.Health = AIPricingHttpServer.ПроверитьСоединение();
    Исключение
        Результат.Ошибки.Добавить("Health: " + ОписаниеОшибки());
    КонецПопытки;

    Попытка
        Результат.ModelInfo = AIPricingHttpServer.ПолучитьИнформациюОМодели();
    Исключение
        Результат.Ошибки.Добавить("ModelInfo: " + ОписаниеОшибки());
    КонецПопытки;

    Попытка
        Результат.MarketContext = AIPricingMarketContextServer.СформироватьMarketContext(ТестоваяНоменклатура);
    Исключение
        Результат.Ошибки.Добавить("MarketContext: " + ОписаниеОшибки());
    КонецПопытки;

    Попытка
        Результат.Recommendation = AIPricingRecommendationsMarketServer.РассчитатьИЗаписатьMarketAwareРекомендацию(ТестоваяНоменклатура);
    Исключение
        Результат.Ошибки.Добавить("Recommendation: " + ОписаниеОшибки());
    КонецПопытки;

    Возврат Результат;

КонецФункции
