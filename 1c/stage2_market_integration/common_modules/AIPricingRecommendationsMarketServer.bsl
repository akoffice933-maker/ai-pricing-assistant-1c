// ОбщийМодуль AIPricingRecommendationsMarketServer
// Свойства: Сервер = Истина, ВызовСервера = Истина.
// Назначение: вызов нового market-aware FastAPI и сохранение рекомендации + demand curve.

Функция РассчитатьИЗаписатьMarketAwareРекомендацию(Номенклатура, Характеристика = Неопределено, ВидЦены = Неопределено, БизнесЦель = "") Экспорт

    JSONВход = "";
    JSONВыход = "";

    Попытка
        ЗапросНавыка = AIPricingDataProviderMarketServer.СформироватьЗапросMarketAware(Номенклатура, Характеристика, ВидЦены, БизнесЦель);
        JSONВход = AIPricingJSONServer.ЗаписатьJSONВСтроку(ЗапросНавыка);

        ОтветHTTP = AIPricingHttpServer.ВызватьНавыкPOST("/skills/recommend_price", JSONВход);
        JSONВыход = ОтветHTTP.Тело;

        Если Не ОтветHTTP.Успех Тогда
            ЗаписатьОшибкуMarketAware(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, ОтветHTTP.Ошибка);
            ВызватьИсключение ОтветHTTP.Ошибка;
        КонецЕсли;

        Результат = ОтветHTTP.Данные;
        ЗаписатьMarketAwareРекомендацию(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, Результат, "Новая", "");

        Возврат Результат;

    Исключение
        Если JSONВход <> "" Тогда
            ЗаписатьОшибкуMarketAware(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, ОписаниеОшибки());
        КонецЕсли;
        ВызватьИсключение;
    КонецПопытки;

КонецФункции

Процедура ЗаписатьMarketAwareРекомендацию(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, Результат, Статус, ПоследняяОшибка = "") Экспорт

    Если Метаданные.РегистрыСведений.Найти("AI_РекомендацииПоЦенам") = Неопределено Тогда
        ВызватьИсключение "Не найден регистр AI_РекомендацииПоЦенам.";
    КонецЕсли;

    Идентификатор = ПолучитьСвойство(Результат, "request_id", Строка(Новый УникальныйИдентификатор()));
    Эффект = Результат;
    MarketSummary = ПолучитьСвойство(Результат, "market_context_summary", Новый Структура);
    Explanation = ПолучитьСвойство(Результат, "explanation", Новый Структура);
    Action = ПолучитьСвойство(Результат, "recommended_action", Новый Структура);

    Запись = РегистрыСведений.AI_РекомендацииПоЦенам.СоздатьМенеджерЗаписи();
    Запись.ИдентификаторРекомендации = Идентификатор;
    Запись.Номенклатура = Номенклатура;

    Если Характеристика <> Неопределено Тогда
        Запись.ХарактеристикаНоменклатуры = Характеристика;
    КонецЕсли;
    Если ВидЦены <> Неопределено Тогда
        Запись.ВидЦены = ВидЦены;
    КонецЕсли;

    Запись.ТекущаяЦена = ПолучитьСвойство(Результат, "current_price", 0);
    Запись.РекомендованнаяЦена = ПолучитьСвойство(Результат, "recommended_price", 0);
    Запись.ИзменениеПроцент = ПолучитьСвойство(Результат, "price_change_percent", 0);
    Запись.Надежность = ПолучитьСвойство(Результат, "confidence", 0);

    // Старые поля маржи/эффекта из Этапа 1.
    Запись.ОжидаемаяМаржа = ПолучитьСвойство(Результат, "expected_margin_percent", 0);
    Запись.ОжидаемыйЭффект = ПолучитьСвойство(Результат, "expected_gross_profit", 0);

    // Новые поля Этапа 2. Если метаданные ещё не добавлены — эти строки нужно добавить после обновления регистра.
    Запись.ItemType = ПолучитьСвойство(Результат, "item_type", "");
    Запись.MarketCategory = ПолучитьСвойство(Результат, "market_category", "");
    Запись.Region = ПолучитьСвойство(MarketSummary, "region", "");
    Запись.Channel = ПолучитьСвойство(MarketSummary, "channel", "");
    Запись.ExpectedDemand = ПолучитьСвойство(Результат, "expected_demand", 0);
    Запись.ExpectedRevenue = ПолучитьСвойство(Результат, "expected_revenue", 0);
    Запись.ExpectedGrossProfit = ПолучитьСвойство(Результат, "expected_gross_profit", 0);
    Запись.ExpectedMarginPercent = ПолучитьСвойство(Результат, "expected_margin_percent", 0);
    Запись.Elasticity = ПолучитьСвойство(Результат, "elasticity", 0);
    Запись.MarketPriceMedian = ПолучитьСвойство(MarketSummary, "market_price_median", 0);
    Запись.MarketDemandIndex = ПолучитьСвойство(MarketSummary, "market_demand_index", 1);

    Если Запись.MarketPriceMedian > 0 Тогда
        Запись.RelativePriceCurrent = Запись.ТекущаяЦена / Запись.MarketPriceMedian;
        Запись.RelativePriceRecommended = Запись.РекомендованнаяЦена / Запись.MarketPriceMedian;
    КонецЕсли;

    Запись.MarketContextJSON = AIPricingJSONServer.ЗаписатьJSONВСтроку(MarketSummary);
    Запись.КриваяСпросаJSON = AIPricingJSONServer.ЗаписатьJSONВСтроку(ПолучитьСвойство(Результат, "demand_curve", Новый Массив));
    Запись.OptimizationJSON = JSONВыход;

    Запись.ДатаРасчета = ТекущаяДата();
    Запись.ДатаИзмененияСтатуса = ТекущаяДата();
    Запись.Статус = Статус;
    Запись.Стратегия = ПолучитьСвойство(Результат, "business_goal", "");
    Запись.РекомендованноеДействие = ПолучитьСвойство(Action, "type", "");
    Запись.Приоритет = ПолучитьСвойство(Action, "priority", "");
    Запись.СрокДействияДней = ПолучитьСвойство(Action, "valid_for_days", 0);
    Запись.ТребуетСогласования = ПолучитьСвойство(Action, "requires_approval", Истина);
    Запись.ВерсияМодели = ПолучитьСвойство(Результат, "model_version", "");

    SummaryArray = ПолучитьСвойство(Explanation, "summary", Новый Массив);
    Запись.КраткоеОбъяснение = МассивВСтроку(SummaryArray);
    Запись.ПоложительныеФакторы = МассивВСтроку(ПолучитьСвойство(Explanation, "positive_factors", Новый Массив));
    Запись.НегативныеФакторы = МассивВСтроку(ПолучитьСвойство(Explanation, "negative_factors", Новый Массив));
    Запись.НейтральныеФакторы = МассивВСтроку(ПолучитьСвойство(Explanation, "neutral_factors", Новый Массив));
    Запись.Предупреждения = МассивВСтроку(ПолучитьСвойство(Результат, "warnings", Новый Массив));

    Запись.JSONВход = JSONВход;
    Запись.JSONВыход = JSONВыход;
    Запись.Пользователь = ИмяПользователя();
    Запись.ПоследняяОшибка = ПоследняяОшибка;

    Запись.Записать();

КонецПроцедуры

Процедура ЗаписатьОшибкуMarketAware(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, ТекстОшибки) Экспорт
    Результат = Новый Структура;
    Результат.Вставить("request_id", Строка(Новый УникальныйИдентификатор()));
    Результат.Вставить("current_price", 0);
    Результат.Вставить("recommended_price", 0);
    Результат.Вставить("confidence", 0);
    Результат.Вставить("model_version", "market-aware-error");
    ЗаписатьMarketAwareРекомендацию(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, Результат, "Ошибка", ТекстОшибки);
КонецПроцедуры

Функция ПолучитьСписокMarketAwareРекомендаций(Фильтр = Неопределено) Экспорт

    Если Фильтр = Неопределено Тогда
        Фильтр = Новый Структура;
    КонецЕсли;

    Запрос = Новый Запрос;
    Текст =
    "ВЫБРАТЬ
    |   Рекомендации.ИдентификаторРекомендации,
    |   Рекомендации.ДатаРасчета,
    |   Рекомендации.Номенклатура,
    |   Рекомендации.ItemType,
    |   Рекомендации.MarketCategory,
    |   Рекомендации.ТекущаяЦена,
    |   Рекомендации.РекомендованнаяЦена,
    |   Рекомендации.ИзменениеПроцент,
    |   Рекомендации.ExpectedDemand,
    |   Рекомендации.ExpectedRevenue,
    |   Рекомендации.ExpectedGrossProfit,
    |   Рекомендации.ExpectedMarginPercent,
    |   Рекомендации.MarketPriceMedian,
    |   Рекомендации.MarketDemandIndex,
    |   Рекомендации.RelativePriceCurrent,
    |   Рекомендации.RelativePriceRecommended,
    |   Рекомендации.Elasticity,
    |   Рекомендации.Надежность,
    |   Рекомендации.Статус,
    |   Рекомендации.КраткоеОбъяснение,
    |   Рекомендации.ДокументИзмененияЦен
    |ИЗ
    |   РегистрСведений.AI_РекомендацииПоЦенам КАК Рекомендации
    |ГДЕ
    |   1 = 1";

    ЗначениеФильтра = Неопределено;
    Если Фильтр.Свойство("ДатаНачала", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.ДатаРасчета >= &ДатаНачала";
        Запрос.УстановитьПараметр("ДатаНачала", ЗначениеФильтра);
    КонецЕсли;
    Если Фильтр.Свойство("ДатаОкончания", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.ДатаРасчета <= &ДатаОкончания";
        Запрос.УстановитьПараметр("ДатаОкончания", ЗначениеФильтра);
    КонецЕсли;
    Если Фильтр.Свойство("Статус", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.Статус = &Статус";
        Запрос.УстановитьПараметр("Статус", ЗначениеФильтра);
    КонецЕсли;
    Если Фильтр.Свойство("MarketCategory", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.MarketCategory = &MarketCategory";
        Запрос.УстановитьПараметр("MarketCategory", ЗначениеФильтра);
    КонецЕсли;

    Запрос.Текст = Текст + Символы.ПС + "УПОРЯДОЧИТЬ ПО Рекомендации.ДатаРасчета УБЫВ";
    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Функция ПолучитьКривуюСпросаJSON(ИдентификаторРекомендации) Экспорт
    Рекомендация = AIPricingRecommendationsServer.ПолучитьРекомендациюПоИдентификатору(ИдентификаторРекомендации);
    Если Рекомендация = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Возврат Рекомендация.КриваяСпросаJSON;
КонецФункции

Функция ПолучитьMarketContextJSON(ИдентификаторРекомендации) Экспорт
    Рекомендация = AIPricingRecommendationsServer.ПолучитьРекомендациюПоИдентификатору(ИдентификаторРекомендации);
    Если Рекомендация = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Возврат Рекомендация.MarketContextJSON;
КонецФункции

Функция ПолучитьСвойство(Данные, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
    Возврат AIPricingMarketContextServer.ПолучитьСвойство(Данные, ИмяСвойства, ЗначениеПоУмолчанию);
КонецФункции

Функция МассивВСтроку(Значение)
    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Если ТипЗнч(Значение) <> Тип("Массив") Тогда
        Возврат Строка(Значение);
    КонецЕсли;
    Результат = "";
    Для Каждого Элемент Из Значение Цикл
        Если Результат <> "" Тогда
            Результат = Результат + Символы.ПС;
        КонецЕсли;
        Результат = Результат + Строка(Элемент);
    КонецЦикла;
    Возврат Результат;
КонецФункции
