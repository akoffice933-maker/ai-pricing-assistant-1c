// ОбщийМодуль AIPricingMarketContextServer
// Свойства: Сервер = Истина, ВызовСервера = Ложь.
// Назначение: формирование market_context из регистра AI_РыночныеИндикаторы.

Функция СформироватьMarketContext(Номенклатура, Регион = "", КаналПродаж = "", ТипПозиции = "") Экспорт

    Если Регион = "" Тогда
        Регион = ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_DefaultRegion", "LV");
    КонецЕсли;

    Если КаналПродаж = "" Тогда
        КаналПродаж = ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_DefaultChannel", "online");
    КонецЕсли;

    Маппинг = ПолучитьМаппингРыночнойКатегории(Номенклатура);

    Если ТипПозиции = "" Тогда
        ТипПозиции = ПолучитьСвойство(Маппинг, "ТипПозиции", ОпределитьТипПозиции(Номенклатура));
    КонецЕсли;

    КатегорияРынка = ПолучитьСвойство(Маппинг, "КатегорияРынка", "");
    Если КатегорияРынка = "" Тогда
        КатегорияРынка = ОпределитьКатегориюРынкаFallback(Номенклатура);
    КонецЕсли;

    Если ПолучитьСвойство(Маппинг, "Регион", "") <> "" Тогда
        Регион = Маппинг.Регион;
    КонецЕсли;

    Если ПолучитьСвойство(Маппинг, "КаналПродаж", "") <> "" Тогда
        КаналПродаж = Маппинг.КаналПродаж;
    КонецЕсли;

    Индикаторы = ПолучитьПоследниеИндикаторы(КатегорияРынка, Регион, КаналПродаж, ТипПозиции);

    Если Индикаторы = Неопределено Тогда
        Индикаторы = СформироватьFallbackИндикаторы(Номенклатура);
    КонецЕсли;

    MarketContext = Новый Структура;
    MarketContext.Вставить("market_category", КатегорияРынка);
    MarketContext.Вставить("region", Регион);
    MarketContext.Вставить("channel", КаналПродаж);
    MarketContext.Вставить("period", Формат(ТекущаяДата(), "ДФ=yyyy-MM"));

    MarketContext.Вставить("market_price_min", ПолучитьСвойство(Индикаторы, "market_price_min", Неопределено));
    MarketContext.Вставить("market_price_p25", ПолучитьСвойство(Индикаторы, "market_price_p25", Неопределено));
    MarketContext.Вставить("market_price_median", ПолучитьСвойство(Индикаторы, "market_price_median", 1));
    MarketContext.Вставить("market_price_avg", ПолучитьСвойство(Индикаторы, "market_price_avg", Неопределено));
    MarketContext.Вставить("market_price_p75", ПолучитьСвойство(Индикаторы, "market_price_p75", Неопределено));
    MarketContext.Вставить("market_price_max", ПолучитьСвойство(Индикаторы, "market_price_max", Неопределено));
    MarketContext.Вставить("competitor_count", ПолучитьСвойство(Индикаторы, "competitor_count", 0));
    MarketContext.Вставить("active_competitor_count", ПолучитьСвойство(Индикаторы, "active_competitor_count", Неопределено));
    MarketContext.Вставить("market_demand_index", ПолучитьСвойство(Индикаторы, "market_demand_index", 1));
    MarketContext.Вставить("search_trend_index", ПолучитьСвойство(Индикаторы, "search_trend_index", Неопределено));
    MarketContext.Вставить("lead_volume_index", ПолучитьСвойство(Индикаторы, "lead_volume_index", Неопределено));
    MarketContext.Вставить("category_views_index", ПолучитьСвойство(Индикаторы, "category_views_index", Неопределено));
    MarketContext.Вставить("promo_share", ПолучитьСвойство(Индикаторы, "promo_share", 0));
    MarketContext.Вставить("average_discount_percent", ПолучитьСвойство(Индикаторы, "average_discount_percent", Неопределено));
    MarketContext.Вставить("availability_index", ПолучитьСвойство(Индикаторы, "availability_index", 1));
    MarketContext.Вставить("stockout_rate", ПолучитьСвойство(Индикаторы, "stockout_rate", Неопределено));
    MarketContext.Вставить("average_delivery_days", ПолучитьСвойство(Индикаторы, "average_delivery_days", Неопределено));
    MarketContext.Вставить("seasonality_index", ПолучитьСвойство(Индикаторы, "seasonality_index", 1));
    MarketContext.Вставить("tender_count", ПолучитьСвойство(Индикаторы, "tender_count", Неопределено));
    MarketContext.Вставить("conversion_benchmark", ПолучитьСвойство(Индикаторы, "conversion_benchmark", Неопределено));
    MarketContext.Вставить("specialist_supply_index", ПолучитьСвойство(Индикаторы, "specialist_supply_index", Неопределено));
    MarketContext.Вставить("wage_index", ПолучитьСвойство(Индикаторы, "wage_index", Неопределено));
    MarketContext.Вставить("data_freshness_days", ПолучитьСвойство(Индикаторы, "data_freshness_days", 999));
    MarketContext.Вставить("source_count", ПолучитьСвойство(Индикаторы, "source_count", Неопределено));
    MarketContext.Вставить("coverage_score", ПолучитьСвойство(Индикаторы, "coverage_score", 1));
    MarketContext.Вставить("confidence", ПолучитьСвойство(Индикаторы, "confidence", 0.3));

    Возврат MarketContext;

КонецФункции

Функция ПолучитьПоследниеИндикаторы(КатегорияРынка, Регион, КаналПродаж, ТипПозиции) Экспорт

    Если Метаданные.РегистрыСведений.Найти("AI_РыночныеИндикаторы") = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |   Индикаторы.MarketPriceMin КАК market_price_min,
    |   Индикаторы.MarketPriceP25 КАК market_price_p25,
    |   Индикаторы.MarketPriceMedian КАК market_price_median,
    |   Индикаторы.MarketPriceAvg КАК market_price_avg,
    |   Индикаторы.MarketPriceP75 КАК market_price_p75,
    |   Индикаторы.MarketPriceMax КАК market_price_max,
    |   Индикаторы.CompetitorCount КАК competitor_count,
    |   Индикаторы.ActiveCompetitorCount КАК active_competitor_count,
    |   Индикаторы.MarketDemandIndex КАК market_demand_index,
    |   Индикаторы.SearchTrendIndex КАК search_trend_index,
    |   Индикаторы.LeadVolumeIndex КАК lead_volume_index,
    |   Индикаторы.CategoryViewsIndex КАК category_views_index,
    |   Индикаторы.PromoShare КАК promo_share,
    |   Индикаторы.AverageDiscountPercent КАК average_discount_percent,
    |   Индикаторы.AvailabilityIndex КАК availability_index,
    |   Индикаторы.StockoutRate КАК stockout_rate,
    |   Индикаторы.AverageDeliveryDays КАК average_delivery_days,
    |   Индикаторы.SeasonalityIndex КАК seasonality_index,
    |   Индикаторы.TenderCount КАК tender_count,
    |   Индикаторы.ConversionBenchmark КАК conversion_benchmark,
    |   Индикаторы.SpecialistSupplyIndex КАК specialist_supply_index,
    |   Индикаторы.WageIndex КАК wage_index,
    |   Индикаторы.DataFreshnessDays КАК data_freshness_days,
    |   Индикаторы.SourceCount КАК source_count,
    |   Индикаторы.CoverageScore КАК coverage_score,
    |   Индикаторы.Confidence КАК confidence
    |ИЗ
    |   РегистрСведений.AI_РыночныеИндикаторы.СрезПоследних(&Дата,
    |       КатегорияРынка = &КатегорияРынка
    |       И Регион = &Регион
    |       И КаналПродаж = &КаналПродаж
    |       И ТипПозиции = &ТипПозиции) КАК Индикаторы
    |УПОРЯДОЧИТЬ ПО
    |   Индикаторы.Период УБЫВ";

    Запрос.УстановитьПараметр("Дата", ТекущаяДата());
    Запрос.УстановитьПараметр("КатегорияРынка", КатегорияРынка);
    Запрос.УстановитьПараметр("Регион", Регион);
    Запрос.УстановитьПараметр("КаналПродаж", КаналПродаж);
    Запрос.УстановитьПараметр("ТипПозиции", ТипПозиции);

    Выборка = Запрос.Выполнить().Выбрать();
    Если Не Выборка.Следующий() Тогда
        Возврат Неопределено;
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("market_price_min", Выборка.market_price_min);
    Результат.Вставить("market_price_p25", Выборка.market_price_p25);
    Результат.Вставить("market_price_median", Выборка.market_price_median);
    Результат.Вставить("market_price_avg", Выборка.market_price_avg);
    Результат.Вставить("market_price_p75", Выборка.market_price_p75);
    Результат.Вставить("market_price_max", Выборка.market_price_max);
    Результат.Вставить("competitor_count", Выборка.competitor_count);
    Результат.Вставить("active_competitor_count", Выборка.active_competitor_count);
    Результат.Вставить("market_demand_index", Выборка.market_demand_index);
    Результат.Вставить("search_trend_index", Выборка.search_trend_index);
    Результат.Вставить("lead_volume_index", Выборка.lead_volume_index);
    Результат.Вставить("category_views_index", Выборка.category_views_index);
    Результат.Вставить("promo_share", Выборка.promo_share);
    Результат.Вставить("average_discount_percent", Выборка.average_discount_percent);
    Результат.Вставить("availability_index", Выборка.availability_index);
    Результат.Вставить("stockout_rate", Выборка.stockout_rate);
    Результат.Вставить("average_delivery_days", Выборка.average_delivery_days);
    Результат.Вставить("seasonality_index", Выборка.seasonality_index);
    Результат.Вставить("tender_count", Выборка.tender_count);
    Результат.Вставить("conversion_benchmark", Выборка.conversion_benchmark);
    Результат.Вставить("specialist_supply_index", Выборка.specialist_supply_index);
    Результат.Вставить("wage_index", Выборка.wage_index);
    Результат.Вставить("data_freshness_days", Выборка.data_freshness_days);
    Результат.Вставить("source_count", Выборка.source_count);
    Результат.Вставить("coverage_score", Выборка.coverage_score);
    Результат.Вставить("confidence", Выборка.confidence);

    Возврат Результат;

КонецФункции

Функция ПолучитьМаппингРыночнойКатегории(Номенклатура) Экспорт

    Результат = Новый Структура;

    Если Метаданные.РегистрыСведений.Найти("AI_МаппингРыночныхКатегорий") = Неопределено Тогда
        Возврат Результат;
    КонецЕсли;

    // 1. Сначала точный маппинг по номенклатуре.
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |   Маппинг.КатегорияРынка,
    |   Маппинг.Регион,
    |   Маппинг.КаналПродаж,
    |   Маппинг.ТипПозиции,
    |   Маппинг.PriceUnit,
    |   Маппинг.QualityIndex
    |ИЗ
    |   РегистрСведений.AI_МаппингРыночныхКатегорий КАК Маппинг
    |ГДЕ
    |   Маппинг.Активен
    |   И Маппинг.Номенклатура = &Номенклатура";
    Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        ЗаполнитьМаппингИзВыборки(Результат, Выборка);
        Возврат Результат;
    КонецЕсли;

    // 2. Затем маппинг по группе.
    Попытка
        Группа = Номенклатура.Родитель;
    Исключение
        Группа = Неопределено;
    КонецПопытки;

    Если ЗначениеЗаполнено(Группа) Тогда
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Маппинг.КатегорияРынка,
        |   Маппинг.Регион,
        |   Маппинг.КаналПродаж,
        |   Маппинг.ТипПозиции,
        |   Маппинг.PriceUnit,
        |   Маппинг.QualityIndex
        |ИЗ
        |   РегистрСведений.AI_МаппингРыночныхКатегорий КАК Маппинг
        |ГДЕ
        |   Маппинг.Активен
        |   И Маппинг.ГруппаНоменклатуры = &Группа";
        Запрос.УстановитьПараметр("Группа", Группа);
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            ЗаполнитьМаппингИзВыборки(Результат, Выборка);
        КонецЕсли;
    КонецЕсли;

    Возврат Результат;

КонецФункции

Процедура ЗаполнитьМаппингИзВыборки(Результат, Выборка)
    Результат.Вставить("КатегорияРынка", Выборка.КатегорияРынка);
    Результат.Вставить("Регион", Выборка.Регион);
    Результат.Вставить("КаналПродаж", Выборка.КаналПродаж);
    Результат.Вставить("ТипПозиции", Выборка.ТипПозиции);
    Результат.Вставить("PriceUnit", Выборка.PriceUnit);
    Результат.Вставить("QualityIndex", Выборка.QualityIndex);
КонецПроцедуры

Функция СформироватьFallbackИндикаторы(Номенклатура)

    ТекущаяЦена = 1;
    Попытка
        ТекущаяЦена = AIPricingDataProviderServer.ПолучитьТекущуюЦену(Номенклатура, Неопределено, Неопределено);
    Исключение
    КонецПопытки;

    Если ТекущаяЦена <= 0 Тогда
        ТекущаяЦена = 1;
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("market_price_median", ТекущаяЦена);
    Результат.Вставить("market_demand_index", 1);
    Результат.Вставить("promo_share", 0);
    Результат.Вставить("availability_index", 1);
    Результат.Вставить("seasonality_index", 1);
    Результат.Вставить("data_freshness_days", 999);
    Результат.Вставить("coverage_score", 0.1);
    Результат.Вставить("confidence", 0.3);

    Возврат Результат;

КонецФункции

Функция ОпределитьТипПозиции(Номенклатура) Экспорт
    Попытка
        Если Номенклатура.ВидНоменклатуры.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
            Возврат "service";
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат "product";
КонецФункции

Функция ОпределитьКатегориюРынкаFallback(Номенклатура) Экспорт
    Попытка
        Если ЗначениеЗаполнено(Номенклатура.Родитель) Тогда
            Возврат Строка(Номенклатура.Родитель);
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат "unknown_market_category";
КонецФункции

Функция ПолучитьСвойство(Данные, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено) Экспорт
    Если Данные = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;
    Значение = Неопределено;
    Попытка
        Если Данные.Свойство(ИмяСвойства, Значение) Тогда
            Если Значение = Null Тогда
                Возврат ЗначениеПоУмолчанию;
            КонецЕсли;
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПолучитьКонстантуИлиЗначениеПоУмолчанию(ИмяКонстанты, ЗначениеПоУмолчанию)
    Попытка
        Если Метаданные.Константы.Найти(ИмяКонстанты) <> Неопределено Тогда
            Возврат Константы[ИмяКонстанты].Получить();
        КонецЕсли;
    Исключение
    КонецПопытки;
    Возврат ЗначениеПоУмолчанию;
КонецФункции
