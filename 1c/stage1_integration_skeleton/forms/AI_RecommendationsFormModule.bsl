// Модуль формы обработки AI_РекомендацииПоЦенам.
// Это skeleton-код. Реквизиты и команды формы описаны в metadata/FORM_SPEC.md.

&НаКлиенте
Процедура ПриОткрытии(Отказ)

    Если Не ЗначениеЗаполнено(ДатаНачала) Тогда
        ДатаНачала = НачалоДня(ТекущаяДата() - 30 * 24 * 60 * 60);
    КонецЕсли;

    Если Не ЗначениеЗаполнено(ДатаОкончания) Тогда
        ДатаОкончания = КонецДня(ТекущаяДата());
    КонецЕсли;

    Если Не ЗначениеЗаполнено(БизнесЦель) Тогда
        БизнесЦель = "maximize_margin";
    КонецЕсли;

    Если Не ЗначениеЗаполнено(МинимальнаяНадежность) Тогда
        МинимальнаяНадежность = 0;
    КонецЕсли;

    ОбновитьСписок(Неопределено);

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписок(Команда)

    Рекомендации = ПолучитьСписокРекомендацийНаСервере();

КонецПроцедуры

&НаСервере
Функция ПолучитьСписокРекомендацийНаСервере()

    Фильтр = Новый Структура;
    Фильтр.Вставить("ДатаНачала", ДатаНачала);
    Фильтр.Вставить("ДатаОкончания", ДатаОкончания);
    Фильтр.Вставить("Статус", ФильтрСтатус);
    Фильтр.Вставить("Номенклатура", ФильтрНоменклатура);
    Фильтр.Вставить("ВидЦены", ФильтрВидЦены);
    Фильтр.Вставить("МинимальнаяНадежность", МинимальнаяНадежность);

    Возврат AIPricingRecommendationsServer.ПолучитьСписокРекомендаций(Фильтр);

КонецФункции

&НаКлиенте
Процедура РассчитатьДляТовара(Команда)

    Если Не ЗначениеЗаполнено(ТекущаяНоменклатура) Тогда
        Сообщить("Выберите номенклатуру для расчёта.");
        Возврат;
    КонецЕсли;

    Попытка
        Результат = РассчитатьДляТовараНаСервере(ТекущаяНоменклатура, Неопределено, ТекущийВидЦены, БизнесЦель);
        Сообщить("AI-рекомендация рассчитана: " + Строка(Результат.recommended_price));
        ОбновитьСписок(Неопределено);
    Исключение
        Сообщить("Ошибка расчёта AI-рекомендации: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

&НаСервере
Функция РассчитатьДляТовараНаСервере(Номенклатура, Характеристика, ВидЦены, БизнесЦель)

    Возврат AIPricingRecommendationsServer.РассчитатьИЗаписатьРекомендацию(
        Номенклатура,
        Характеристика,
        ВидЦены,
        БизнесЦель
    );

КонецФункции

&НаКлиенте
Процедура ПринятьРекомендацию(Команда)

    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;

    AIPricingRecommendationsServer.ОбновитьСтатусРекомендации(Идентификатор, "Принята");
    ОбновитьСписок(Неопределено);

КонецПроцедуры

&НаКлиенте
Процедура ОтклонитьРекомендацию(Команда)

    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;

    Причина = "";
    // В production лучше открыть отдельную форму ввода причины.
    ВвестиСтроку(Причина, "Укажите причину отклонения", 500);

    Если Не ЗначениеЗаполнено(Причина) Тогда
        Сообщить("Причина отклонения обязательна.");
        Возврат;
    КонецЕсли;

    AIPricingRecommendationsServer.ОбновитьСтатусРекомендации(Идентификатор, "Отклонена", Причина);
    ОбновитьСписок(Неопределено);

КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументЦен(Команда)

    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;

    Попытка
        Результат = AIPricingDocumentsServer.СоздатьЧерновикУстановкиЦен(Идентификатор);
        Сообщить("Создан черновик документа: " + Строка(Результат.ДокументСсылка));
        ОбновитьСписок(Неопределено);
    Исключение
        Сообщить("Не удалось создать документ установки цен: " + ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьJSON(Команда)

    Идентификатор = ПолучитьИдентификаторТекущейРекомендации();
    Если Идентификатор = "" Тогда
        Возврат;
    КонецЕсли;

    ДанныеJSON = ПолучитьJSONРекомендацииНаСервере(Идентификатор);

    Сообщить("JSON вход:" + Символы.ПС + ДанныеJSON.JSONВход);
    Сообщить("JSON выход:" + Символы.ПС + ДанныеJSON.JSONВыход);

КонецПроцедуры

&НаСервере
Функция ПолучитьJSONРекомендацииНаСервере(Идентификатор)

    Рекомендация = AIPricingRecommendationsServer.ПолучитьРекомендациюПоИдентификатору(Идентификатор);
    Результат = Новый Структура;

    Если Рекомендация = Неопределено Тогда
        Результат.Вставить("JSONВход", "");
        Результат.Вставить("JSONВыход", "");
    Иначе
        Результат.Вставить("JSONВход", Рекомендация.JSONВход);
        Результат.Вставить("JSONВыход", Рекомендация.JSONВыход);
    КонецЕсли;

    Возврат Результат;

КонецФункции

&НаКлиенте
Функция ПолучитьИдентификаторТекущейРекомендации()

    Если Элементы.Рекомендации.ТекущиеДанные = Неопределено Тогда
        Сообщить("Выберите рекомендацию.");
        Возврат "";
    КонецЕсли;

    Возврат Элементы.Рекомендации.ТекущиеДанные.ИдентификаторРекомендации;

КонецФункции

&НаКлиенте
Процедура ПроверитьСоединение(Команда)

    Результат = ПроверитьСоединениеНаСервере();

    Если Результат.Успех Тогда
        Сообщить("AI-сервис доступен: " + Результат.Тело);
    Иначе
        Сообщить("AI-сервис недоступен: " + Результат.Ошибка);
    КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПроверитьСоединениеНаСервере()

    Возврат AIPricingHttpServer.ПроверитьСоединение();

КонецФункции
