КонецФункции

Функция ВызватьНавыкPOST(ОтносительныйПуть, JSONТело) Экспорт

    Настройки = AIPricingSettingsServer.ПолучитьНастройки();
    Путь = AIPricingSettingsServer.ПолучитьПутьAPI(ОтносительныйПуть);

    Результат = Новый Структура;
    Результат.Вставить("Успех", Ложь);
    Результат.Вставить("КодСостояния", 0);
    Результат.Вставить("Тело", "");
    Результат.Вставить("Данные", Неопределено);
    Результат.Вставить("Ошибка", "");

    Попытка
        HTTPСоединение = СоздатьСоединение(Настройки);
        HTTPЗапрос = Новый HTTPЗапрос(Путь);
        HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        HTTPЗапрос.Заголовки.Вставить("Accept", "application/json");

        Если ЗначениеЗаполнено(Настройки.APIToken) Тогда
            HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + Настройки.APIToken);
        КонецЕсли;

        HTTPЗапрос.УстановитьТелоИзСтроки(JSONТело, КодировкаТекста.UTF8);

        HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
        ЗаполнитьРезультатHTTP(Результат, HTTPОтвет);

    Исключение
        Результат.Ошибка = ОписаниеОшибки();
    КонецПопытки;

    Возврат Результат;

КонецФункции

Функция ВыполнитьGET(ОтносительныйПуть) Экспорт

    Настройки = AIPricingSettingsServer.ПолучитьНастройки();
    Путь = AIPricingSettingsServer.ПолучитьПутьAPI(ОтносительныйПуть);

    Результат = Новый Структура;
    Результат.Вставить("Успех", Ложь);
    Результат.Вставить("КодСостояния", 0);
    Результат.Вставить("Тело", "");
    Результат.Вставить("Данные", Неопределено);
    Результат.Вставить("Ошибка", "");

    Попытка
        HTTPСоединение = СоздатьСоединение(Настройки);
        HTTPЗапрос = Новый HTTPЗапрос(Путь);
        HTTPЗапрос.Заголовки.Вставить("Accept", "application/json");

        Если ЗначениеЗаполнено(Настройки.APIToken) Тогда
            HTTPЗапрос.Заголовки.Вставить("Authorization", "Bearer " + Настройки.APIToken);
        КонецЕсли;

        HTTPОтвет = HTTPСоединение.Получить(HTTPЗапрос);
        ЗаполнитьРезультатHTTP(Результат, HTTPОтвет);

    Исключение
        Результат.Ошибка = ОписаниеОшибки();
    КонецПопытки;

    Возврат Результат;

КонецФункции

Функция СоздатьСоединение(Настройки)

    ЗащищенноеСоединение = Неопределено;

    Если Настройки.UseHTTPS Тогда
        ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
    КонецЕсли;

    Возврат Новый HTTPСоединение(
        Настройки.Host,
        Настройки.Port,
        ,
        ,
        ,
        Настройки.Timeout,
        ЗащищенноеСоединение
    );

КонецФункции

Процедура ЗаполнитьРезультатHTTP(Результат, HTTPОтвет)

    Результат.КодСостояния = HTTPОтвет.КодСостояния;
    Результат.Тело = HTTPОтвет.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

    Если HTTPОтвет.КодСостояния >= 200 И HTTPОтвет.КодСостояния < 300 Тогда
        Результат.Успех = Истина;
        Если Результат.Тело <> "" Тогда
            Результат.Данные = AIPricingJSONServer.ПрочитатьJSONИзСтроки(Результат.Тело);
        КонецЕсли;
    Иначе
        Результат.Ошибка = "HTTP " + Строка(HTTPОтвет.КодСостояния) + ": " + Результат.Тело;
    КонецЕсли;

КонецПроцедуры
