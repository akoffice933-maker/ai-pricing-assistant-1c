// ОбщийМодуль AIPricingSettingsServer
// Свойства: Сервер = Истина, Клиент = Ложь, ВызовСервера = Ложь.
// Назначение: централизованные настройки подключения к FastAPI и бизнес-правил.

Функция ПолучитьНастройки() Экспорт

    Настройки = Новый Структура;

    Настройки.Вставить("Host", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_Host", "localhost"));
    Настройки.Вставить("Port", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_Port", 8000));
    Настройки.Вставить("UseHTTPS", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_UseHTTPS", Ложь));
    Настройки.Вставить("BasePath", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_BasePath", ""));
    Настройки.Вставить("APIToken", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_APIToken", ""));
    Настройки.Вставить("Timeout", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_Timeout", 30));

    Возврат Настройки;

КонецФункции

Функция ПолучитьНастройкиРасчета() Экспорт

    НастройкиРасчета = Новый Структура;
    НастройкиРасчета.Вставить("min_confidence_for_apply", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MinConfidence", 0.70));
    НастройкиРасчета.Вставить("max_price_increase_percent", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MaxIncreasePercent", 20));
    НастройкиРасчета.Вставить("max_price_decrease_percent", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MaxDecreasePercent", 30));
    НастройкиРасчета.Вставить("min_margin_percent", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_MinMarginPercent", 10));
    НастройкиРасчета.Вставить("price_ending", ПолучитьКонстантуИлиЗначениеПоУмолчанию("AI_Pricing_PriceEnding", 0.99));

    Возврат НастройкиРасчета;

КонецФункции

Функция ПолучитьКонстантуИлиЗначениеПоУмолчанию(ИмяКонстанты, ЗначениеПоУмолчанию) Экспорт

    // Позволяет сначала запустить скелет без всех констант.
    // В production лучше сделать константы обязательными и валидировать настройки при запуске.
    Попытка
        Если Метаданные.Константы.Найти(ИмяКонстанты) = Неопределено Тогда
            Возврат ЗначениеПоУмолчанию;
        КонецЕсли;

        Возврат Константы[ИмяКонстанты].Получить();
    Исключение
        Возврат ЗначениеПоУмолчанию;
    КонецПопытки;

КонецФункции

Функция ПолучитьПутьAPI(ОтносительныйПуть) Экспорт

    Настройки = ПолучитьНастройки();
    BasePath = Настройки.BasePath;

    Если BasePath = Неопределено Тогда
        BasePath = "";
    КонецЕсли;

    Если Лев(ОтносительныйПуть, 1) <> "/" Тогда
        ОтносительныйПуть = "/" + ОтносительныйПуть;
    КонецЕсли;

    Если BasePath <> "" И Лев(BasePath, 1) <> "/" Тогда
        BasePath = "/" + BasePath;
    КонецЕсли;

    Возврат BasePath + ОтносительныйПуть;

КонецФункции
