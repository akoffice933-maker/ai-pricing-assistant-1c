// ОбщийМодуль AIPricingDocumentsServer
// Свойства: Сервер = Истина, ВызовСервера = Истина.
// Назначение: создание непроведённого документа УстановкаЦенНоменклатуры.

Функция СоздатьЧерновикУстановкиЦен(ИдентификаторРекомендации) Экспорт

    Рекомендация = AIPricingRecommendationsServer.ПолучитьРекомендациюПоИдентификатору(ИдентификаторРекомендации);
    Если Рекомендация = Неопределено Тогда
        ВызватьИсключение "AI-рекомендация не найдена: " + ИдентификаторРекомендации;
    КонецЕсли;

    Если Рекомендация.РекомендованнаяЦена <= 0 Тогда
        ВызватьИсключение "Рекомендованная цена не заполнена.";
    КонецЕсли;

    Если Метаданные.Документы.Найти("УстановкаЦенНоменклатуры") = Неопределено Тогда
        ВызватьИсключение "В конфигурации нет документа УстановкаЦенНоменклатуры. Адаптируйте AIPricingDocumentsServer под вашу конфигурацию.";
    КонецЕсли;

    ДокументОбъект = Документы.УстановкаЦенНоменклатуры.СоздатьДокумент();
    ДокументОбъект.Дата = ТекущаяДата();
    ДокументОбъект.Комментарий = "Создано по AI-рекомендации " + ИдентификаторРекомендации
        + ". Документ не проведён автоматически.";

    МДДокумента = ДокументОбъект.Метаданные();

    // В разных конфигурациях вид цены может быть реквизитом шапки или колонкой табличной части.
    Если МДДокумента.Реквизиты.Найти("ВидЦены") <> Неопределено Тогда
        УстановитьСвойство(ДокументОбъект, "ВидЦены", Рекомендация.ВидЦены);
    КонецЕсли;

    Если МДДокумента.ТабличныеЧасти.Найти("Товары") = Неопределено Тогда
        ВызватьИсключение "В документе УстановкаЦенНоменклатуры не найдена табличная часть Товары.";
    КонецЕсли;

    СтрокаТЧ = ДокументОбъект.Товары.Добавить();
    МДТовары = МДДокумента.ТабличныеЧасти.Товары;

    Если МДТовары.Реквизиты.Найти("Номенклатура") <> Неопределено Тогда
        УстановитьСвойство(СтрокаТЧ, "Номенклатура", Рекомендация.Номенклатура);
    КонецЕсли;

    Если МДТовары.Реквизиты.Найти("Характеристика") <> Неопределено Тогда
        УстановитьСвойство(СтрокаТЧ, "Характеристика", Рекомендация.ХарактеристикаНоменклатуры);
    ИначеЕсли МДТовары.Реквизиты.Найти("ХарактеристикаНоменклатуры") <> Неопределено Тогда
        УстановитьСвойство(СтрокаТЧ, "ХарактеристикаНоменклатуры", Рекомендация.ХарактеристикаНоменклатуры);
    КонецЕсли;

    Если МДТовары.Реквизиты.Найти("ВидЦены") <> Неопределено Тогда
        УстановитьСвойство(СтрокаТЧ, "ВидЦены", Рекомендация.ВидЦены);
    КонецЕсли;

    Если МДТовары.Реквизиты.Найти("Цена") <> Неопределено Тогда
        УстановитьСвойство(СтрокаТЧ, "Цена", Рекомендация.РекомендованнаяЦена);
    ИначеЕсли МДТовары.Реквизиты.Найти("НоваяЦена") <> Неопределено Тогда
        УстановитьСвойство(СтрокаТЧ, "НоваяЦена", Рекомендация.РекомендованнаяЦена);
    Иначе
        ВызватьИсключение "В табличной части Товары не найдена колонка Цена/НоваяЦена.";
    КонецЕсли;

    Если МДТовары.Реквизиты.Найти("Комментарий") <> Неопределено Тогда
        УстановитьСвойство(СтрокаТЧ, "Комментарий", "AI: " + ИдентификаторРекомендации);
    КонецЕсли;

    // Только запись, без проведения.
    ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);

    AIPricingRecommendationsServer.УстановитьДокументРекомендации(ИдентификаторРекомендации, ДокументОбъект.Ссылка);

    Результат = Новый Структура;
    Результат.Вставить("ДокументСсылка", ДокументОбъект.Ссылка);
    Результат.Вставить("ИдентификаторРекомендации", ИдентификаторРекомендации);
    Результат.Вставить("Проведен", Ложь);

    Возврат Результат;

КонецФункции

Процедура УстановитьСвойство(Объект, ИмяСвойства, Значение)

    Данные = Новый Структура;
    Данные.Вставить(ИмяСвойства, Значение);
    ЗаполнитьЗначенияСвойств(Объект, Данные);

КонецПроцедуры
