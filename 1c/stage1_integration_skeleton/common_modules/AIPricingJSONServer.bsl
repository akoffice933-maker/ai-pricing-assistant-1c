// ОбщийМодуль AIPricingJSONServer
// Свойства: Сервер = Истина.
// Назначение: JSON-сериализация и безопасная работа со структурами ответа API.

Функция ЗаписатьJSONВСтроку(Данные) Экспорт

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    СтрокаJSON = ЗаписьJSON.Закрыть();

    Возврат СтрокаJSON;

КонецФункции

Функция ПрочитатьJSONИзСтроки(СтрокаJSON) Экспорт

    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
    Данные = ПрочитатьJSON(ЧтениеJSON);
    ЧтениеJSON.Закрыть();

    Возврат Данные;

КонецФункции

Функция ПолучитьСвойство(Объект, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено) Экспорт

    Если Объект = Неопределено Тогда
        Возврат ЗначениеПоУмолчанию;
    КонецЕсли;

    Попытка
        Значение = Неопределено;
        Если Объект.Свойство(ИмяСвойства, Значение) Тогда
            Возврат Значение;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат ЗначениеПоУмолчанию;

КонецФункции

Функция ПолучитьВложенноеСвойство(Объект, ИмяОбъекта, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено) Экспорт

    ВложенныйОбъект = ПолучитьСвойство(Объект, ИмяОбъекта, Неопределено);
    Возврат ПолучитьСвойство(ВложенныйОбъект, ИмяСвойства, ЗначениеПоУмолчанию);

КонецФункции

Функция МассивВСтроку(Значение, Разделитель = Символы.ПС) Экспорт

    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    Если ТипЗнч(Значение) <> Тип("Массив") Тогда
        Возврат Строка(Значение);
    КонецЕсли;

    Результат = "";
    Для Каждого Элемент Из Значение Цикл
        Если Результат <> "" Тогда
            Результат = Результат + Разделитель;
        КонецЕсли;
        Результат = Результат + Строка(Элемент);
    КонецЦикла;

    Возврат Результат;

КонецФункции
