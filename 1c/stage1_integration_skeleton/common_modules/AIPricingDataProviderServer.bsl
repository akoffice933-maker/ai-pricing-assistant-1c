// ОбщийМодуль AIPricingDataProviderServer
// Свойства: Сервер = Истина, ВызовСервера = Ложь.
// Назначение: адаптер данных 1С → JSON-контракт FastAPI.
// ВАЖНО: запросы в этом модуле нужно адаптировать под конкретную конфигурацию 1С.

Функция СформироватьЗапросРекомендацииЦены(Номенклатура, Характеристика = Неопределено, ВидЦены = Неопределено, БизнесЦель = "maximize_margin") Экспорт

    Если Не ЗначениеЗаполнено(Номенклатура) Тогда
        ВызватьИсключение "Не указана номенклатура для расчёта AI-рекомендации.";
    КонецЕсли;

    ТекущаяЦена = ПолучитьТекущуюЦену(Номенклатура, Характеристика, ВидЦены);
    Себестоимость = ПолучитьСебестоимость(Номенклатура, Характеристика);
    Остаток = ПолучитьОстаток(Номенклатура, Характеристика);
    Продажи30 = ПолучитьПродажиЗаПериод(Номенклатура, Характеристика, 30);
    Продажи90 = ПолучитьПродажиЗаПериод(Номенклатура, Характеристика, 90);

    Если ТекущаяЦена <= 0 Тогда
        ВызватьИсключение "Не удалось определить текущую цену товара.";
    КонецЕсли;

    Если Себестоимость <= 0 Тогда
        ВызватьИсключение "Не удалось определить себестоимость товара.";
    КонецЕсли;

    Запрос = Новый Структура;
    Запрос.Вставить("request_id", Строка(Новый УникальныйИдентификатор()));
    Запрос.Вставить("user_id", ИмяПользователя());
    Запрос.Вставить("business_goal", БизнесЦель);

    Товар = Новый Структура;
    Товар.Вставить("product_id", ПолучитьИдентификаторСсылки(Номенклатура));
    Товар.Вставить("product_name", Строка(Номенклатура));
    Товар.Вставить("category", ПолучитьКатегориюНоменклатуры(Номенклатура));
    Товар.Вставить("current_price", ТекущаяЦена);
    Товар.Вставить("production_cost", Себестоимость);
    Товар.Вставить("logistics_cost", ПолучитьЛогистическиеРасходы(Номенклатура, Характеристика));
    Товар.Вставить("stock_quantity", Остаток);
    Товар.Вставить("sales_last_30_days", Продажи30);
    Товар.Вставить("sales_last_90_days", Продажи90);
    Товар.Вставить("supplier_reliability", ПолучитьНадежностьПоставщика(Номенклатура));
    Товар.Вставить("customer_rating", ПолучитьРейтингТовара(Номенклатура));
    Товар.Вставить("seasonal_index", ПолучитьИндексСезонности(Номенклатура));
    Товар.Вставить("brand_value", ПолучитьСилуБренда(Номенклатура));
    Товар.Вставить("target_margin_percent", ПолучитьЦелевуюМаржу(Номенклатура));

    Запрос.Вставить("product", Товар);

    ДанныеКонкурентов = ПолучитьДанныеКонкурентов(Номенклатура);
    Если ДанныеКонкурентов <> Неопределено Тогда
        Запрос.Вставить("competitor", ДанныеКонкурентов);
    КонецЕсли;

    Флаги = Новый Структура;
    Флаги.Вставить("is_promo", ТоварУчаствуетВАкции(Номенклатура));
    Флаги.Вставить("price_locked", ЦенаЗаблокирована(Номенклатура));
    Флаги.Вставить("allow_create_price_document", Истина);
    Запрос.Вставить("flags", Флаги);

    Запрос.Вставить("settings", AIPricingSettingsServer.ПолучитьНастройкиРасчета());

    Возврат Запрос;

КонецФункции

Функция ПолучитьИдентификаторСсылки(Ссылка)

    Попытка
        Возврат Строка(Ссылка.УникальныйИдентификатор());
    Исключение
        Возврат Строка(Ссылка);
    КонецПопытки;

КонецФункции

Функция ПолучитьКатегориюНоменклатуры(Номенклатура) Экспорт

    Попытка
        Если ЗначениеЗаполнено(Номенклатура.Родитель) Тогда
            Возврат Строка(Номенклатура.Родитель);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат "Без категории";

КонецФункции

Функция ПолучитьТекущуюЦену(Номенклатура, Характеристика, ВидЦены) Экспорт

    // Универсальный шаблон для регистра сведений ЦеныНоменклатуры.
    // Для УТ/ERP может потребоваться добавить Упаковку, Характеристику, Валюту, соглашения и т.д.
    Попытка
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Цены.Цена КАК Цена
        |ИЗ
        |   РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Дата, Номенклатура = &Номенклатура) КАК Цены
        |ГДЕ
        |   Цены.Цена > 0";

        Если ЗначениеЗаполнено(ВидЦены) Тогда
            Запрос.Текст = Запрос.Текст + Символы.ПС + "И Цены.ВидЦены = &ВидЦены";
            Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
        КонецЕсли;

        Запрос.УстановитьПараметр("Дата", ТекущаяДата());
        Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат Выборка.Цена;
        КонецЕсли;
    Исключение
        // В production заменить на фактический источник цен конкретной конфигурации.
    КонецПопытки;

    Возврат 0;

КонецФункции

