КонецФункции

Функция ПолучитьОстаток(Номенклатура, Характеристика) Экспорт

    // TODO production: адаптировать под регистр остатков конкретной конфигурации.
    Попытка
        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ
        |   СУММА(Остатки.КоличествоОстаток) КАК Количество
        |ИЗ
        |   РегистрНакопления.ТоварыНаСкладах.Остатки(&Дата, Номенклатура = &Номенклатура) КАК Остатки";
        Запрос.УстановитьПараметр("Дата", ТекущаяДата());
        Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат ?(Выборка.Количество = Null, 0, Выборка.Количество);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат 0;

КонецФункции

Функция ПолучитьПродажиЗаПериод(Номенклатура, Характеристика, КоличествоДней) Экспорт

    // TODO production: заменить на фактический регистр продаж.
    // Для ряда конфигураций это может быть Продажи.Обороты или ВыручкаИСебестоимостьПродаж.Обороты.
    Попытка
        ДатаКон = ТекущаяДата();
        ДатаНач = ДатаКон - КоличествоДней * 24 * 60 * 60;

        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ
        |   СУММА(Продажи.КоличествоОборот) КАК Количество
        |ИЗ
        |   РегистрНакопления.Продажи.Обороты(&ДатаНач, &ДатаКон, , Номенклатура = &Номенклатура) КАК Продажи";
        Запрос.УстановитьПараметр("ДатаНач", ДатаНач);
        Запрос.УстановитьПараметр("ДатаКон", ДатаКон);
        Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Возврат ?(Выборка.Количество = Null, 0, Выборка.Количество);
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат 0;

КонецФункции

