        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Себестоимость.Стоимость КАК Стоимость
        |ИЗ
        |   РегистрСведений.AI_СебестоимостьНоменклатуры.СрезПоследних(&Дата, Номенклатура = &Номенклатура) КАК Себестоимость";
        Запрос.УстановитьПараметр("Дата", ТекущаяДата());
