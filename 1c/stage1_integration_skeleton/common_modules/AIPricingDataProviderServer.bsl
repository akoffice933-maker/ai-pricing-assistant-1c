Функция ПолучитьДанныеКонкурентов(Номенклатура) Экспорт

    // Опциональный пользовательский регистр сведений AI_ЦеныКонкурентов:
    // Номенклатура, ЦенаМин, ЦенаСредняя, ЦенаМакс, КоличествоКонкурентов, ДатаДанных.
    Попытка
        Если Метаданные.РегистрыСведений.Найти("AI_ЦеныКонкурентов") = Неопределено Тогда
            Возврат Неопределено;
        КонецЕсли;

        Запрос = Новый Запрос;
        Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Цены.ЦенаМин КАК ЦенаМин,
        |   Цены.ЦенаСредняя КАК ЦенаСредняя,
        |   Цены.ЦенаМакс КАК ЦенаМакс,
        |   Цены.КоличествоКонкурентов КАК КоличествоКонкурентов,
        |   Цены.ДатаДанных КАК ДатаДанных
        |ИЗ
        |   РегистрСведений.AI_ЦеныКонкурентов КАК Цены
        |ГДЕ
        |   Цены.Номенклатура = &Номенклатура
        |УПОРЯДОЧИТЬ ПО
        |   Цены.ДатаДанных УБЫВ";
        Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

        Выборка = Запрос.Выполнить().Выбрать();
        Если Выборка.Следующий() Тогда
            Данные = Новый Структура;
            Данные.Вставить("competitor_price_min", Выборка.ЦенаМин);
            Данные.Вставить("competitor_price_avg", Выборка.ЦенаСредняя);
            Данные.Вставить("competitor_price_max", Выборка.ЦенаМакс);
            Данные.Вставить("competitor_count", Выборка.КоличествоКонкурентов);
            Данные.Вставить("data_freshness_days", Цел((ТекущаяДата() - Выборка.ДатаДанных) / (24 * 60 * 60)));
            Возврат Данные;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат Неопределено;

КонецФункции
