// ОбщийМодуль AIPricingRecommendationsServer
// Свойства: Сервер = Истина, ВызовСервера = Истина.
// Назначение: orchestration на стороне 1С: собрать данные, вызвать FastAPI, сохранить аудит.

Функция РассчитатьИЗаписатьРекомендацию(Номенклатура, Характеристика = Неопределено, ВидЦены = Неопределено, БизнесЦель = "maximize_margin") Экспорт

    JSONВход = "";
    JSONВыход = "";

    Попытка
        ЗапросНавыка = AIPricingDataProviderServer.СформироватьЗапросРекомендацииЦены(
            Номенклатура,
            Характеристика,
            ВидЦены,
            БизнесЦель
        );

        JSONВход = AIPricingJSONServer.ЗаписатьJSONВСтроку(ЗапросНавыка);
        ОтветHTTP = AIPricingHttpServer.ВызватьНавыкPOST("/skills/recommend_price", JSONВход);
        JSONВыход = ОтветHTTP.Тело;

        Если Не ОтветHTTP.Успех Тогда
            ЗаписатьОшибкуРекомендации(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, ОтветHTTP.Ошибка);
            ВызватьИсключение ОтветHTTP.Ошибка;
        КонецЕсли;

        Результат = ОтветHTTP.Данные;
        ЗаписатьРекомендациюПоЦене(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, Результат, "Новая", "");

        Возврат Результат;

    Исключение
        Если JSONВход <> "" Тогда
            ЗаписатьОшибкуРекомендации(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, ОписаниеОшибки());
        КонецЕсли;
        ВызватьИсключение;
    КонецПопытки;

КонецФункции

Процедура ЗаписатьРекомендациюПоЦене(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, Результат, Статус, ПоследняяОшибка = "") Экспорт

    Эффект = AIPricingJSONServer.ПолучитьСвойство(Результат, "expected_effect", Новый Структура);
    Риск = AIPricingJSONServer.ПолучитьСвойство(Результат, "risk", Новый Структура);
    Объяснение = AIPricingJSONServer.ПолучитьСвойство(Результат, "explanation", Новый Структура);
    Действие = AIPricingJSONServer.ПолучитьСвойство(Результат, "recommended_action", Новый Структура);

    Идентификатор = AIPricingJSONServer.ПолучитьСвойство(Результат, "request_id", "");
    Если Идентификатор = "" Тогда
        Идентификатор = Строка(Новый УникальныйИдентификатор());
    КонецЕсли;

    Запись = РегистрыСведений.AI_РекомендацииПоЦенам.СоздатьМенеджерЗаписи();
    Запись.ИдентификаторРекомендации = Идентификатор;
    Запись.Номенклатура = Номенклатура;

    Если Характеристика <> Неопределено Тогда
        Запись.ХарактеристикаНоменклатуры = Характеристика;
    КонецЕсли;

    Если ВидЦены <> Неопределено Тогда
        Запись.ВидЦены = ВидЦены;
    КонецЕсли;

    Запись.ТекущаяЦена = AIPricingJSONServer.ПолучитьСвойство(Результат, "current_price", 0);
    Запись.РекомендованнаяЦена = AIPricingJSONServer.ПолучитьСвойство(Результат, "recommended_price", 0);
    Запись.НижняяГраницаЦены = AIPricingJSONServer.ПолучитьСвойство(Результат, "confidence_interval_lower", 0);
    Запись.ВерхняяГраницаЦены = AIPricingJSONServer.ПолучитьСвойство(Результат, "confidence_interval_upper", 0);
    Запись.ИзменениеПроцент = AIPricingJSONServer.ПолучитьСвойство(Результат, "price_change_percent", 0);
    Запись.Надежность = AIPricingJSONServer.ПолучитьСвойство(Результат, "confidence", 0);

    Запись.ТекущаяМаржа = AIPricingJSONServer.ПолучитьСвойство(Эффект, "current_margin_percent", 0);
    Запись.ОжидаемаяМаржа = AIPricingJSONServer.ПолучитьСвойство(Эффект, "new_margin_percent", 0);
    Запись.ИзменениеМаржи = AIPricingJSONServer.ПолучитьСвойство(Эффект, "margin_change_percent", 0);
    Запись.ОжидаемыйЭффект = AIPricingJSONServer.ПолучитьСвойство(Эффект, "expected_profit_change_monthly", 0);
    Запись.ОжидаемоеИзменениеОбъема = AIPricingJSONServer.ПолучитьСвойство(Эффект, "expected_volume_change_percent", 0);

    Запись.ДатаРасчета = ТекущаяДата();
    Запись.ДатаИзмененияСтатуса = ТекущаяДата();
    Запись.Статус = Статус;
    Запись.УровеньРиска = AIPricingJSONServer.ПолучитьСвойство(Риск, "level", "");
    Запись.Стратегия = AIPricingJSONServer.ПолучитьСвойство(Результат, "business_goal", "");
    Запись.РекомендованноеДействие = AIPricingJSONServer.ПолучитьСвойство(Действие, "type", "");
    Запись.Приоритет = AIPricingJSONServer.ПолучитьСвойство(Действие, "priority", "");
    Запись.СрокДействияДней = AIPricingJSONServer.ПолучитьСвойство(Действие, "valid_for_days", 0);
    Запись.ТребуетСогласования = AIPricingJSONServer.ПолучитьСвойство(Действие, "requires_approval", Истина);
    Запись.ВерсияМодели = AIPricingJSONServer.ПолучитьСвойство(Результат, "model_version", "");

    Запись.КраткоеОбъяснение = AIPricingJSONServer.ПолучитьСвойство(Объяснение, "summary", "");
    Запись.ПоложительныеФакторы = AIPricingJSONServer.МассивВСтроку(AIPricingJSONServer.ПолучитьСвойство(Объяснение, "positive_factors", Новый Массив));
    Запись.НегативныеФакторы = AIPricingJSONServer.МассивВСтроку(AIPricingJSONServer.ПолучитьСвойство(Объяснение, "negative_factors", Новый Массив));
    Запись.НейтральныеФакторы = AIPricingJSONServer.МассивВСтроку(AIPricingJSONServer.ПолучитьСвойство(Объяснение, "neutral_factors", Новый Массив));
    Запись.Предупреждения = AIPricingJSONServer.МассивВСтроку(AIPricingJSONServer.ПолучитьСвойство(Результат, "warnings", Новый Массив));

    Запись.JSONВход = JSONВход;
    Запись.JSONВыход = JSONВыход;
    Запись.Пользователь = ИмяПользователя();
    Запись.ПоследняяОшибка = ПоследняяОшибка;

    Запись.Записать();

КонецПроцедуры

Процедура ЗаписатьОшибкуРекомендации(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, ТекстОшибки) Экспорт

    Результат = Новый Структура;
    Результат.Вставить("request_id", Строка(Новый УникальныйИдентификатор()));
    Результат.Вставить("current_price", 0);
    Результат.Вставить("recommended_price", 0);
    Результат.Вставить("confidence", 0);
    Результат.Вставить("model_version", "unknown");

    ЗаписатьРекомендациюПоЦене(Номенклатура, Характеристика, ВидЦены, JSONВход, JSONВыход, Результат, "Ошибка", ТекстОшибки);

КонецПроцедуры

Функция ПолучитьСписокРекомендаций(Фильтр = Неопределено) Экспорт

    Если Фильтр = Неопределено Тогда
        Фильтр = Новый Структура;
    КонецЕсли;

    Запрос = Новый Запрос;
    Текст =
    "ВЫБРАТЬ
    |   Рекомендации.ИдентификаторРекомендации КАК ИдентификаторРекомендации,
    |   Рекомендации.ДатаРасчета КАК ДатаРасчета,
    |   Рекомендации.Номенклатура КАК Номенклатура,
    |   Рекомендации.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
    |   Рекомендации.ВидЦены КАК ВидЦены,
    |   Рекомендации.ТекущаяЦена КАК ТекущаяЦена,
    |   Рекомендации.РекомендованнаяЦена КАК РекомендованнаяЦена,
    |   Рекомендации.ИзменениеПроцент КАК ИзменениеПроцент,
    |   Рекомендации.ТекущаяМаржа КАК ТекущаяМаржа,
    |   Рекомендации.ОжидаемаяМаржа КАК ОжидаемаяМаржа,
    |   Рекомендации.ОжидаемыйЭффект КАК ОжидаемыйЭффект,
    |   Рекомендации.Надежность КАК Надежность,
    |   Рекомендации.УровеньРиска КАК УровеньРиска,
    |   Рекомендации.Статус КАК Статус,
    |   Рекомендации.ВерсияМодели КАК ВерсияМодели,
    |   Рекомендации.КраткоеОбъяснение КАК КраткоеОбъяснение,
    |   Рекомендации.ДокументИзмененияЦен КАК ДокументИзмененияЦен
    |ИЗ
    |   РегистрСведений.AI_РекомендацииПоЦенам КАК Рекомендации
    |ГДЕ
    |   1 = 1";

    ЗначениеФильтра = Неопределено;

    Если Фильтр.Свойство("ДатаНачала", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.ДатаРасчета >= &ДатаНачала";
        Запрос.УстановитьПараметр("ДатаНачала", ЗначениеФильтра);
    КонецЕсли;

    Если Фильтр.Свойство("ДатаОкончания", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.ДатаРасчета <= &ДатаОкончания";
        Запрос.УстановитьПараметр("ДатаОкончания", ЗначениеФильтра);
    КонецЕсли;

    Если Фильтр.Свойство("Статус", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.Статус = &Статус";
        Запрос.УстановитьПараметр("Статус", ЗначениеФильтра);
    КонецЕсли;

    Если Фильтр.Свойство("Номенклатура", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.Номенклатура = &Номенклатура";
        Запрос.УстановитьПараметр("Номенклатура", ЗначениеФильтра);
    КонецЕсли;

    Если Фильтр.Свойство("ВидЦены", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.ВидЦены = &ВидЦены";
        Запрос.УстановитьПараметр("ВидЦены", ЗначениеФильтра);
    КонецЕсли;

    Если Фильтр.Свойство("МинимальнаяНадежность", ЗначениеФильтра) И ЗначениеЗаполнено(ЗначениеФильтра) Тогда
        Текст = Текст + Символы.ПС + "И Рекомендации.Надежность >= &МинимальнаяНадежность";
        Запрос.УстановитьПараметр("МинимальнаяНадежность", ЗначениеФильтра);
    КонецЕсли;

    Текст = Текст + Символы.ПС + "УПОРЯДОЧИТЬ ПО Рекомендации.ДатаРасчета УБЫВ";
    Запрос.Текст = Текст;

    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Процедура ОбновитьСтатусРекомендации(ИдентификаторРекомендации, НовыйСтатус, ПричинаОтклонения = "") Экспорт

    Набор = РегистрыСведений.AI_РекомендацииПоЦенам.СоздатьНаборЗаписей();
    Набор.Отбор.ИдентификаторРекомендации.Установить(ИдентификаторРекомендации);
    Набор.Прочитать();

    Для Каждого Запись Из Набор Цикл
        Запись.Статус = НовыйСтатус;
        Запись.ДатаИзмененияСтатуса = ТекущаяДата();
        Запись.Пользователь = ИмяПользователя();

        Если НовыйСтатус = "Принята" Тогда
            Запись.ДатаПринятия = ТекущаяДата();
        КонецЕсли;

        Если НовыйСтатус = "Отклонена" Тогда
            Запись.ПричинаОтклонения = ПричинаОтклонения;
        КонецЕсли;
    КонецЦикла;

    Набор.Записать();

КонецПроцедуры

Функция ПолучитьРекомендациюПоИдентификатору(ИдентификаторРекомендации) Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |   Рекомендации.*
    |ИЗ
    |   РегистрСведений.AI_РекомендацииПоЦенам КАК Рекомендации
    |ГДЕ
    |   Рекомендации.ИдентификаторРекомендации = &ИдентификаторРекомендации";
    Запрос.УстановитьПараметр("ИдентификаторРекомендации", ИдентификаторРекомендации);

    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка;
    КонецЕсли;

    Возврат Неопределено;

КонецФункции

Процедура УстановитьДокументРекомендации(ИдентификаторРекомендации, ДокументСсылка) Экспорт

    Набор = РегистрыСведений.AI_РекомендацииПоЦенам.СоздатьНаборЗаписей();
    Набор.Отбор.ИдентификаторРекомендации.Установить(ИдентификаторРекомендации);
    Набор.Прочитать();

    Для Каждого Запись Из Набор Цикл
        Запись.ДокументИзмененияЦен = ДокументСсылка;
        Запись.Статус = "Принята";
        Запись.ДатаПринятия = ТекущаяДата();
        Запись.ДатаИзмененияСтатуса = ТекущаяДата();
        Запись.Пользователь = ИмяПользователя();
    КонецЦикла;

    Набор.Записать();

КонецПроцедуры
